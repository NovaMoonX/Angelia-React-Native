{
  "name": "angelia",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "expo": {
    "router": {
      "appDir": "src/app"
    }
  },
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "env:android": "eas env:delete && eas env:create --name GOOGLE_SERVICES_JSON --type file --visibility sensitive --value ./google-services.json --environment development",
    "build:android": "eas build --profile development --platform android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "ts:check": "tsc --noEmit",
    "prebuild": "expo prebuild",
    "postinstall": "npx patch-package",
    "env:pull": "eas env:pull --environment development --output .env.development"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.1",
    "@react-native-firebase/app": "^21.6.1",
    "@react-native-firebase/auth": "^21.6.1",
    "@react-native-firebase/firestore": "^21.6.1",
    "@react-native-firebase/storage": "^21.6.1",
    "@react-native-google-signin/google-signin": "^13.3.1",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.3.14",
    "@reduxjs/toolkit": "^2.11.2",
    "expo": "~55.0.14",
    "expo-build-properties": "~55.0.13",
    "expo-camera": "^55.0.15",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.11",
    "expo-dev-client": "~55.0.26",
    "expo-device": "~55.0.14",
    "expo-font": "~55.0.6",
    "expo-image": "~55.0.8",
    "expo-image-picker": "~55.0.18",
    "expo-linking": "~55.0.12",
    "expo-router": "~55.0.12",
    "expo-splash-screen": "~55.0.17",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.15",
    "expo-video": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "memoize-one": "^6.0.0",
    "nanoid": "^5.1.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "react-redux": "^9.2.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "@types/uuid": "^10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
