{
	"name": "angelia",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"expo": {
		"router": {
			"appDir": "src/app"
		}
	},
	"scripts": {
		"start": "expo start",
		"start:clean": "expo start --clear",
		"android:devices": "adb kill-server && adb start-server && adb devices",
		"android": "expo run:android --device",
		"android:clean": "expo run:android --device --no-build-cache",
		"prebuild:android": "expo prebuild --platform android",
		"prebuild:android:clean": "expo prebuild --platform android --clean",
		"env:android": "eas env:delete && eas env:create --name GOOGLE_SERVICES_JSON --type file --visibility sensitive --value ./google-services.json --environment development",
		"build:android": "eas build --profile development --platform android",
		"ios": "expo run:ios",
		"web": "expo start --web",
		"lint": "expo lint",
		"ts:check": "tsc --noEmit",
		"prebuild": "expo prebuild",
		"postinstall": "npx patch-package",
		"env:pull": "eas env:pull --environment development --output .env.development",
		"packages:check": "npx expo install --check",
		"deploy:rules:firestore": "firebase deploy --only firestore:rules",
		"deploy:rules:storage": "firebase deploy --only storage",
		"deploy:rules": "firebase deploy --only firestore:rules,storage",
		"deploy:functions": "cd functions && npm run build && firebase deploy --only functions",
		"deploy:all": "cd functions && npm run build && cd .. && firebase deploy --only firestore:rules,storage,functions"
	},
	"dependencies": {
		"@expo/vector-icons": "^15.0.2",
		"@react-native-async-storage/async-storage": "2.2.0",
		"@react-native-clipboard/clipboard": "^1.16.1",
		"@react-native-community/datetimepicker": "8.6.0",
		"@react-native-firebase/app": "^21.6.1",
		"@react-native-firebase/auth": "^21.6.1",
		"@react-native-firebase/firestore": "^21.6.1",
		"@react-native-firebase/messaging": "^21.14.0",
		"@react-native-firebase/storage": "^21.6.1",
		"@react-native-google-signin/google-signin": "^13.3.1",
		"@react-navigation/native": "^7.1.33",
		"@react-navigation/native-stack": "^7.3.14",
		"@reduxjs/toolkit": "^2.11.2",
		"@shopify/flash-list": "2.0.2",
		"date-fns": "^4.1.0",
		"expo": "~55.0.14",
		"expo-build-properties": "~55.0.13",
		"expo-clipboard": "~55.0.13",
		"expo-constants": "~55.0.11",
		"expo-crypto": "~55.0.14",
		"expo-dev-client": "~55.0.26",
		"expo-device": "~55.0.14",
		"expo-font": "~55.0.6",
		"expo-image": "~55.0.8",
		"expo-image-manipulator": "~55.0.15",
		"expo-image-picker": "~55.0.18",
		"expo-linking": "~55.0.12",
		"expo-notifications": "^55.0.19",
		"expo-router": "~55.0.12",
		"expo-splash-screen": "~55.0.17",
		"expo-status-bar": "~55.0.5",
		"expo-system-ui": "~55.0.15",
		"expo-video": "~55.0.15",
		"expo-web-browser": "~55.0.14",
		"lottie-react-native": "^7.3.6",
		"memoize-one": "^6.0.0",
		"nanoid": "^5.1.6",
		"react": "19.2.0",
		"react-dom": "19.2.0",
		"react-native": "0.83.6",
		"react-native-gesture-handler": "~2.30.0",
		"react-native-qrcode-svg": "^6.3.12",
		"react-native-reanimated": "4.2.1",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-screens": "~4.23.0",
		"react-native-svg": "15.15.3",
		"react-native-vision-camera": "^4.7.3",
		"react-native-web": "~0.21.0",
		"react-native-worklets": "0.7.4",
		"react-redux": "^9.2.0",
		"uuid": "^11.1.0"
	},
	"devDependencies": {
		"@types/react": "~19.2.2",
		"@types/uuid": "^10.0.0",
		"typescript": "~5.9.2"
	},
	"overrides": {
		"@react-native-async-storage/async-storage": "2.2.0"
	},
	"private": true
}
