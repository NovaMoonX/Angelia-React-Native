rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    // Helper: verify a user profile document exists
    function userProfileExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    // Helper: check if the requesting user is a member (owner or subscriber) of a channel.
    // Accepts a channelId so the same logic can be reused across different match blocks.
    function isChannelMember(channelId) {
      let channel = get(/databases/$(database)/documents/channels/$(channelId));
      return isSignedIn() &&
        exists(/databases/$(database)/documents/channels/$(channelId)) &&
        (
          channel.data.ownerId == request.auth.uid
          || (
            (channel.data.subscribers is list) &&
            (request.auth.uid in channel.data.subscribers)
          )
        );
    }

    // Users collection
    match /users/{userId} {
      // A user can always read their own profile.
      allow get: if isSignedIn() && request.auth.uid == userId;

      // Channel members need to read each other's profiles to display post author
      // names and avatars (populated via subscribeToChannelUsers). Firestore rules
      // cannot perform collection queries to find shared channels without a known
      // channelId, so we permit any authenticated user to read user profiles.
      // Access scoping is enforced at the data layer: subscribeToChannelUsers only
      // requests the IDs of owners/subscribers from the requester's accessible channels.
      allow read: if isSignedIn();

      // Users can only write to their own profile
      allow create, update: if isSignedIn() && request.auth.uid == userId;

      // Prevent deletion of user profiles
      allow delete: if false;
    }
    
    // Channels collection
    match /channels/{channelId} {
      function isOwner() {
        return isSignedIn() && request.auth.uid == resource.data.ownerId;
      }

      function isOwnerOnCreate() {
        return isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      }

      function isSubscriber() {
        return isSignedIn()
          && (resource.data.subscribers is list)
          && (request.auth.uid in resource.data.subscribers);
      }

      // Any authenticated user may read a channel document in order to
      // look it up by channelId when following an invite URL.
      allow read: if isSignedIn();

      // Create: only authenticated users can create a channel for themselves.
      // Require that the creating user has a profile document in `/users/{uid}`.
      // Additionally enforce a limit on custom (non-daily) channels. Clients
      // must maintain a `customChannelCount` integer on the user's
      // document (`users/{uid}.customChannelCount`). Creation of a non-daily
      // channel is allowed only when that count is < 3. Daily channels are
      // exempt from this limit, but the user profile must still exist.
      allow create: if isOwnerOnCreate()
        // Require the user's profile to exist in `/users/{uid}`
        && userProfileExists(request.auth.uid)
        && (
          // Allow creating daily channels when the user exists
          request.resource.data.isDaily == true
          // Or allow creating non-daily channels only when the user's
          // `customChannelCount` exists and is less than 3
          || (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.customChannelCount is int
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.customChannelCount < 3
          )
        )

      // Update: only owner may modify; ownerId and id cannot be changed
      allow update: if isOwner()
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.id == resource.data.id

      // Unsubscribe: a subscriber may remove only themselves from the subscribers list.
      // All other fields must remain unchanged.
      allow update: if isSubscriber()
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.id == resource.data.id
        && request.resource.data.inviteCode == resource.data.inviteCode
        && request.resource.data.name == resource.data.name
        && request.resource.data.description == resource.data.description
        && request.resource.data.color == resource.data.color
        && request.resource.data.isDaily == resource.data.isDaily
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.markedForDeletionAt == resource.data.markedForDeletionAt
        && request.resource.data.subscribers.size() == resource.data.subscribers.size() - 1
        && request.resource.data.subscribers.toSet().hasOnly(resource.data.subscribers.toSet())
        && !request.resource.data.subscribers.hasAny([request.auth.uid])
        && resource.data.subscribers.toSet().difference(request.resource.data.subscribers.toSet()).hasOnly([request.auth.uid])

      // Deletion: owners may delete their custom (non-daily) channels.
      // Daily channels are system-managed and cannot be deleted by clients.
      allow delete: if isOwner() && resource.data.isDaily == false;
    }

    // Posts collection
    match /posts/{postId} {
      function isAuthor() {
        return isSignedIn() && request.auth.uid == resource.data.authorId;
      }
      function isAuthorOnCreate() {
        return isSignedIn() && request.auth.uid == request.resource.data.authorId;
      }
      // Returns true when the requesting user is in the post author's connections list.
      // Only applicable to daily channels so that stand-alone connections grant Daily Circle access.
      function isConnectedToAuthorDailyChannel() {
        let ch = get(/databases/$(database)/documents/channels/$(resource.data.channelId));
        return isSignedIn()
          && ch.data.isDaily == true
          && exists(/databases/$(database)/documents/connections/$(resource.data.authorId)/people/$(request.auth.uid));
      }

      // Channel owners and subscribers may read posts in their channel.
      // Connected users may also read posts in their connections' daily channels.
      allow read: if isAuthor()
        || isChannelMember(resource.data.channelId)
        || isConnectedToAuthorDailyChannel();

      // Only the author can create a post for themselves
      allow create: if isAuthorOnCreate();

      // Only the author can update their post (cannot change authorId)
      allow update: if isAuthor()
        && request.resource.data.authorId == resource.data.authorId;

      // Channel members who have reacted may join the conversation
      // (append themselves to conversationEnrollees) without being the post author.
      // Only the conversationEnrollees field may change; everything else must stay the same.
      allow update: if isSignedIn()
        && isChannelMember(resource.data.channelId)
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.channelId == resource.data.channelId
        && request.resource.data.text == resource.data.text
        && request.resource.data.timestamp == resource.data.timestamp
        && request.resource.data.reactions == resource.data.reactions
        && request.resource.data.comments == resource.data.comments
        && request.resource.data.status == resource.data.status
        && request.resource.data.markedForDeletionAt == resource.data.markedForDeletionAt
        && request.resource.data.conversationEnrollees is list
        && request.resource.data.conversationEnrollees.size() == resource.data.conversationEnrollees.size() + 1
        && request.resource.data.conversationEnrollees.toSet().hasAll(resource.data.conversationEnrollees.toSet())
        && request.resource.data.conversationEnrollees.hasAny([request.auth.uid]);

      // Only the author can delete their post
      allow delete: if isAuthor();

      // Messages subcollection under posts
      match /messages/{messageId} {
        // Any authenticated channel member may read messages
        allow read: if isSignedIn()
          && isChannelMember(get(/databases/$(database)/documents/posts/$(postId)).data.channelId);

        // Any authenticated user who has reacted to the post may create a message
        allow create: if isSignedIn()
          && request.auth.uid == request.resource.data.authorId;

        // Messages cannot be updated or deleted
        allow update, delete: if false;
      }
    }

    // Channel join requests
    match /channelJoinRequests/{requestId} {
      function isRequester() {
        return isSignedIn() && request.auth.uid == resource.data.requesterId;
      }
      function isRequesterOnCreate() {
        return isSignedIn() && request.auth.uid == request.resource.data.requesterId;
      }
      function isChannelOwner() {
        return isSignedIn() && request.auth.uid == resource.data.channelOwnerId;
      }

      // The requester and the channel owner may read a join request
      allow read: if isRequester() || isChannelOwner();

      // Only authenticated users can create a request for themselves
      // and the channelOwnerId must match the actual channel document
      allow create: if isRequesterOnCreate()
        && request.resource.data.status == 'pending'
        && request.resource.data.respondedAt == null
        && exists(/databases/$(database)/documents/channels/$(request.resource.data.channelId));

      // Only the channel owner may update status (accept/decline)
      allow update: if isChannelOwner()
        && request.resource.data.requesterId == resource.data.requesterId
        && request.resource.data.channelId == resource.data.channelId
        && request.resource.data.channelOwnerId == resource.data.channelOwnerId;

      allow delete: if false;
    }

    // User notification settings
    match /userNotificationSettings/{userId} {
      // Users can only read their own notification settings
      allow read: if isSignedIn() && request.auth.uid == userId;

      // Users can only create their own notification settings
      allow create: if isSignedIn() && request.auth.uid == userId;

      // Users can only update their own notification settings
      allow update: if isSignedIn() && request.auth.uid == userId;

      // Prevent deletion of notification settings
      allow delete: if false;
    }

    // App notifications — written by the app, processed & deleted by Cloud Functions.
    // Clients only need create access; the Admin SDK handles reads and deletes.
    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    // Feedback submissions — written by the authenticated submitter only.
    // Staff review via Firebase Console / Admin SDK; no client reads.
    match /feedback/{feedbackId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Connection requests — sent by one user to another.
    match /connectionRequests/{requestId} {
      function isRequester() {
        return isSignedIn() && request.auth.uid == resource.data.fromId;
      }
      function isHost() {
        return isSignedIn() && request.auth.uid == resource.data.toId;
      }
      function isRequesterOnCreate() {
        return isSignedIn() && request.auth.uid == request.resource.data.fromId;
      }

      // Both parties may read a request they are involved in.
      allow read: if isRequester() || isHost();

      // Only the requester may create a pending request for themselves.
      allow create: if isRequesterOnCreate()
        && request.resource.data.status == 'pending'
        && request.resource.data.respondedAt == null;

      // Only the host may update the status (accept/decline).
      // Core fields cannot change.
      allow update: if isHost()
        && request.resource.data.fromId == resource.data.fromId
        && request.resource.data.toId == resource.data.toId
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if false;
    }

    // Connections — mutual connections written by Cloud Function on acceptance.
    // Each user can only read their own connections list.
    match /connections/{userId}/people/{personId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Writes are handled exclusively by the Admin SDK (Cloud Function).
      allow create, update, delete: if false;
    }

    // Default: deny all reads and writes not explicitly allowed above.
    // This prevents accidental open-read rules from exposing private data.
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
